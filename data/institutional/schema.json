{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fortune-hunter.local/schemas/institutional-trades.schema.json",
  "title": "台股法人買賣超 point-in-time 資料",
  "type": "object",
  "required": ["version", "sourceStatus", "generatedAt", "records"],
  "properties": {
    "version": { "type": "string" },
    "sourceStatus": {
      "type": "string",
      "enum": ["待確認", "可自動化", "需人工匯入"]
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "records": {
      "type": "array",
      "items": { "$ref": "#/$defs/record" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "record": {
      "type": "object",
      "required": [
        "date",
        "symbol",
        "name",
        "foreignBuy",
        "foreignSell",
        "foreignNetBuy",
        "trustBuy",
        "trustSell",
        "trustNetBuy",
        "dealerBuy",
        "dealerSell",
        "dealerNetBuy",
        "source",
        "publishedAt",
        "effectiveDate",
        "updatedAt",
        "isPointInTimeSafe",
        "notes"
      ],
      "properties": {
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "symbol": {
          "type": "string",
          "pattern": "^[0-9A-Za-z.-]{2,20}$"
        },
        "name": { "type": "string" },
        "foreignBuy": { "type": "number" },
        "foreignSell": { "type": "number" },
        "foreignNetBuy": { "type": "number" },
        "trustBuy": { "type": "number" },
        "trustSell": { "type": "number" },
        "trustNetBuy": { "type": "number" },
        "dealerBuy": { "type": "number" },
        "dealerSell": { "type": "number" },
        "dealerNetBuy": { "type": "number" },
        "source": { "type": "string" },
        "publishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "effectiveDate": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "isPointInTimeSafe": { "type": "boolean" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
